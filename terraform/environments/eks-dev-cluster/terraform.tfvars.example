# Copy this file to terraform.tfvars for local use.

# Infra now defaults to eu-north-1. The current clusters/eks-dev GitOps overlay
# still hardcodes us-east-1, so update that repo to match before running the
# demo end to end.
artifact_bucket_name = "hybrid-workflows-eks-dev-artifacts"

# Optional overrides for the demo cluster:
# aws_region         = "eu-north-1"
# aws_profile        = "eks-dev"
# kubernetes_version = "1.32"
# node_instance_type = "t3.medium"
# vpc_cidr           = "10.50.0.0/16"
