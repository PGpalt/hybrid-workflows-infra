# Copy this file to terraform.tfvars for local use.

kubeconfig_context = "minikube"

# First apply with this left as false so Terraform can install Argo CD and its
# CRDs. After that succeeds, set it to true and apply again to create the root
# Application.
enable_root_application = false

# Terraform hashes this before passing it to the Argo CD Helm chart.
argocd_admin_password = "replace-me"

# Rotate these locally and do not commit the resulting terraform.tfvars file.
minio_access_key = "replace-me"
minio_secret_key = "replace-me"
